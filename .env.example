# AssemblyAI Configuration
# Get your API key from https://www.assemblyai.com/dashboard


# =========================================================
# Neo4j Graph Layer (optional — used for GraphRAG memory)
# ---------------------------------------------------------
# The app runs fine without these. If absent, the graph
# layer is disabled and Convex/MongoDB behavior is unchanged.
#
# Create a free Aura instance at https://neo4j.com/cloud/aura/
# =========================================================
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional tuning
NEO4J_GRAPH_ENABLED=true
NEO4J_GRAPH_MAX_DEPTH=2
NEO4J_GRAPH_CONTEXT_LIMIT=12
